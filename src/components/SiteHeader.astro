---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/contact', label: 'Contact' },
  { href: 'https://github.com/Adman-Corp', label: 'GitHub', external: true }
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href="/">Adman Inc.</a>
    <nav aria-label="Primary">
      <ul class="site-header__nav">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={{ active: !item.external && currentPath === item.href }}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noreferrer' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <a class="button site-header__cta" href="/contact">Start a conversation</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
    background: rgba(245, 243, 239, 0.82);
    border-bottom: 1px solid rgba(216, 221, 217, 0.85);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 4.5rem;
  }

  .site-header__brand {
    font-weight: 700;
    letter-spacing: -0.03em;
    text-decoration: none;
  }

  .site-header__nav {
    display: none;
    align-items: center;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-header__nav a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .site-header__nav a.active,
  .site-header__nav a:hover {
    color: var(--color-text);
  }

  .site-header__cta {
    display: none;
  }

  @media (min-width: 48rem) {
    .site-header__nav,
    .site-header__cta {
      display: inline-flex;
    }
  }
</style>

---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/contact', label: 'Contact' },
  { href: 'https://github.com/Adman-Corp', label: 'GitHub', external: true }
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href="/" aria-label="Adman Inc.">
      <img class="site-header__brand-symbol" src="/symbole.png" alt="" aria-hidden="true" />
      <span class="site-header__brand-wordmark-wrap" aria-hidden="true">
        <img class="site-header__brand-wordmark" src="/Wordmark.png" alt="" />
      </span>
    </a>
    <nav aria-label="Primary">
      <ul class="site-header__nav">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={{ active: !item.external && currentPath === item.href }}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noreferrer' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <a class="button site-header__cta" href="/contact">Start a conversation</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(14px);
    background: rgba(245, 247, 244, 0.88);
    border-bottom: 1px solid rgba(216, 224, 228, 0.92);
  }

  .site-header__inner {
    display: flex;
    position: relative;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 5.75rem;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    flex-shrink: 0;
    text-decoration: none;
  }

  .site-header__brand-symbol,
  .site-header__brand-wordmark-wrap {
    display: block;
  }

  .site-header__brand-symbol {
    width: 2.8rem;
    height: 2.8rem;
    object-fit: contain;
  }

  .site-header__brand-wordmark-wrap {
    position: relative;
    width: 15rem;
    height: 6rem;
    overflow: hidden;
  }

  .site-header__brand-wordmark {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 151%;
    max-width: none;
    height: auto;
    transform: translate(-63.2%, -47.25%);
  }

  .site-header__nav {
    display: none;
    align-items: center;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-header__nav a {
    color: var(--color-muted);
    text-decoration: none;
    transition: color 160ms ease;
  }

  .site-header__nav a.active,
  .site-header__nav a:hover {
    color: var(--color-accent);
  }

  .site-header__cta {
    display: none;
  }

  @media (min-width: 48rem) {
    .site-header__nav {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, calc(-50% + 0.22rem));
      display: inline-flex;
    }

    .site-header__cta {
      display: inline-flex;
    }
  }
</style>
